@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
    var isCliente = User.IsInRole("Cliente");
}

<div class="container mt-2">
    <div class="text-center mb-5">
        <i class="bi bi-wrench-adjustable text-teal" style="font-size: 4rem;"></i>
        <h1 class="display-4 fw-bold text-white mt-3">Taller <span class="text-teal">Mecánico</span></h1>
        <p class="lead text-muted-dark">Sistema integral para gestionar clientes, vehículos y servicios.</p>
    </div>

    @if (!isCliente)
    {
        <div class="row g-4 mb-5">
            
            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #0dcaf0;">
                    <i class="bi bi-people fs-1 text-info mb-3"></i>
                    <h3 class="text-white fw-bold">Clientes</h3>
                    <p class="text-muted-dark flex-grow-1">Gestión de clientes y sus datos de contacto.</p>
                    <a asp-page="/Clientes/Index" class="btn btn-outline-info w-100 mt-auto shadow-sm">Ir a Clientes</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #ffc107;">
                    <i class="bi bi-car-front fs-1 text-warning mb-3"></i>
                    <h3 class="text-white fw-bold">Vehículos</h3>
                    <p class="text-muted-dark flex-grow-1">Control de vehículos registrados y su estado general.</p>
                    <a asp-page="/Vehiculos/Index" class="btn btn-outline-warning w-100 mt-auto shadow-sm">Ir a Vehículos</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #20c997;">
                    <i class="bi bi-clipboard2-data fs-1 text-teal mb-3"></i>
                    <h3 class="text-white fw-bold">Órdenes</h3>
                    <p class="text-muted-dark flex-grow-1">Administración de servicios, diagnósticos y presupuestos.</p>
                    <a asp-page="/ordentrabajo/Index" class="btn btn-teal w-100 mt-auto text-white shadow-sm">Ir a Órdenes</a>
                </div>
            </div>
        </div>
    }

    @if (!isCliente)
    {
        <div class="card-dark p-4 shadow-sm border-0 mb-4">
            <h5 class="text-white border-bottom border-secondary pb-3 mb-4">
                <i class="bi bi-lightning-charge text-warning me-2"></i>Acciones rápidas
            </h5>
            <div class="d-flex flex-wrap gap-3 justify-content-center">
                <a asp-page="/Clientes/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-person-plus me-2 text-info"></i>Nuevo Cliente
                </a>
                <a asp-page="/Vehiculos/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-car-front-fill me-2 text-warning"></i>Ingresar Vehículo
                </a>
                <a asp-page="/ordentrabajo/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-tools me-2 text-teal"></i>Abrir orden
                </a>
            </div>
        </div>
    }
</div>

@if (TempData["PasswordChangedSuccess"] != null)
{
    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #2c3e50; color: #fff; border-radius: 12px;">
                <div class="modal-header border-0">
                    <div class="text-center w-100">
                        <div style="width: 60px; height: 60px; background: rgba(39, 174, 96, 0.2); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 15px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#27ae60" viewBox="0 0 16 16">
                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02.022Z"/>
                            </svg>
                        </div>
                        <h5 class="modal-title" id="successModalLabel" style="color: #fff;">¡Contraseña actualizada!</h5>
                    </div>
                </div>
                <div class="modal-body text-center" style="padding: 0 30px 20px;">
                    <p style="color: rgba(255,255,255,0.7); margin: 0;">Su contraseña ha sido cambiada exitosamente.</p>
                </div>
                <div class="modal-footer border-0 justify-content-center">
                    <button type="button" class="btn" data-bs-dismiss="modal" style="background: #27ae60; color: #fff; padding: 10px 40px; border-radius: 30px; border: none;">
                        Aceptar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            window.addEventListener('DOMContentLoaded', function () {
                var modal = new bootstrap.Modal(document.getElementById('successModal'));
                modal.show();
            });
        </script>
    }
}
